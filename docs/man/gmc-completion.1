.TH "GMC" "1" "Jun 2026" "gmc" "GMC Manual"

.SH NAME
gmc-completion - Generate shell completion script


.SH SYNOPSIS
\fBgmc completion [bash|zsh|fish|powershell]\fP


.SH DESCRIPTION
Generate shell completion script for gmc.

.PP
Add the following to your shell's rc file:

.PP
# Bash (~/.bashrc)
  source <(gmc completion bash)

.PP
# Zsh (~/.zshrc)
  source <(gmc completion zsh)

.PP
# Fish (~/.config/fish/config.fish)
  gmc completion fish | source

.PP
# PowerShell
  gmc completion powershell | Out-String | Invoke-Expression


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	Config file (default: $XDG_CONFIG_HOME/gmc/config.yaml)

.PP
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB-o\fP, \fB--output\fP="text"
	Output format: text or json


.SH SEE ALSO
\fBgmc(1)\fP


